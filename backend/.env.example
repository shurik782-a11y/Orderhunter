# OrderHunter backend
DATABASE_URL=postgresql+asyncpg://orderhunter:orderhunter@localhost:5433/orderhunter
DATABASE_URL_SYNC=postgresql://orderhunter:orderhunter@localhost:5433/orderhunter

# Notify bot (aiogram)
BOT_TOKEN=
ADMIN_TELEGRAM_IDS=123456789

# Internal API (mtproto-worker → backend)
INTERNAL_API_SECRET=change-me-internal-secret

# LLM (OpenAI-compatible: DeepSeek, OpenRouter, etc.)
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_ENABLED=true

# FL.ru (Playwright session)
FL_RU_ENABLED=false
FL_RU_LOGIN=
FL_RU_PASSWORD=
FL_RU_POLL_INTERVAL_SECONDS=300
FL_RU_CATEGORY_URL=https://www.fl.ru/projects/category/programmirovanie/

# Kwork (unofficial API)
KWORK_ENABLED=false
KWORK_LOGIN=
KWORK_PASSWORD=
KWORK_POLL_INTERVAL_SECONDS=300

# Handler CRM integration
HANDLER_LEADS_ENABLED=false
HANDLER_LEADS_URL=http://localhost:3000/api/leads

# Worker
WORKER_ENABLED=true
CONFIG_DIR=../config
