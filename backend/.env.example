# OrderHunter backend
DATABASE_URL=postgresql+asyncpg://orderhunter:orderhunter@localhost:5433/orderhunter
DATABASE_URL_SYNC=postgresql://orderhunter:orderhunter@localhost:5433/orderhunter

# Notify bot (aiogram)
BOT_TOKEN=
ADMIN_TELEGRAM_IDS=123456789

# Internal API (mtproto-worker → backend)
INTERNAL_API_SECRET=change-me-internal-secret

# LLM — DeepSeek ИЛИ OpenRouter (не смешивать ключ и base URL)
# OpenRouter:
LLM_ENABLED=true
LLM_API_KEY=sk-or-v1-...
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-chat

# DeepSeek (альтернатива):
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat

# FL.ru (Playwright session)
FL_RU_ENABLED=false
FL_RU_LOGIN=
FL_RU_PASSWORD=
FL_RU_POLL_INTERVAL_SECONDS=300
FL_RU_CATEGORY_URL=https://www.fl.ru/projects/category/programmirovanie/

# Kwork (unofficial API)
KWORK_ENABLED=false
KWORK_LOGIN=
KWORK_PASSWORD=
KWORK_POLL_INTERVAL_SECONDS=300

# Freelance.ru (Playwright, Assist: open URL + paste draft)
FREELANCE_RU_ENABLED=false
FREELANCE_RU_POLL_INTERVAL_SECONDS=300
FREELANCE_RU_SEARCH_URL=https://freelance.ru/project/search?q=python

# Freelancehunt (Playwright, Assist)
FREELANCEHUNT_ENABLED=false
FREELANCEHUNT_POLL_INTERVAL_SECONDS=300
FREELANCEHUNT_PROJECTS_URL=https://freelancehunt.com/projects/skill/veb-programmirovanie/99.html

# Workspace.ru tenders (Playwright, Assist)
WORKSPACE_RU_ENABLED=false
WORKSPACE_RU_POLL_INTERVAL_SECONDS=300
WORKSPACE_RU_PROJECTS_URL=https://workspace.ru/tenders/web-development/

# Handler CRM integration
HANDLER_LEADS_ENABLED=false
HANDLER_LEADS_URL=http://localhost:3000/api/leads

# Worker
WORKER_ENABLED=true
CONFIG_DIR=../config
